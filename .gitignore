data/*.db
data/*.db-wal
data/*.db-shm

# raw dataset files (fetched by fetch-data, too large to commit)
data/*.txt
data/*.part

# write-behind durability journal
data/search-journal.log
*.log

# local env overrides
.env

# misc
.DS_Store
Thumbs.db
npm-debug.log*
