# Copy to .env to override any of these. Values shown are the defaults.

# ---- server ----
PORT=3000

# ---- primary store (SQLite) ----
DB_PATH=data/quicksuggest.db
DATA_DIR=data
LOAD_LIMIT=300000          # top-N queries (by count) loaded into the in-memory index at boot

# ---- suggestions ----
SUGGEST_LIMIT=10
PRECOMPUTE_LEN=3           # prefixes up to this length keep a maintained top-K bucket
POOL_SIZE=60               # candidate pool size for the recency re-rank
MAX_SCAN=50000             # safety cap on a long-prefix range scan

# ---- distributed cache (in-process logical nodes) ----
CACHE_NODES=4
CACHE_REPLICAS=160         # virtual nodes per logical node on the hash ring
CACHE_CAPACITY=5000        # entries per node before LRU eviction
CACHE_TTL_MS=30000
TRENDING_TTL_MS=5000
CACHE_TTL_JITTER=0.15
INVALIDATE_MAX_LEN=6

# ---- write-behind batching ----
FLUSH_INTERVAL_MS=2000
FLUSH_BATCH_SIZE=200
JOURNAL_ENABLED=true
JOURNAL_PATH=data/search-journal.log

# ---- recency window (trending) ----
WINDOW_BUCKETS=60
BUCKET_MS=10000            # 60 x 10s = 10-minute sliding window
TRENDING_LIMIT=10
RECENCY_WEIGHT=2.5         # weight of the recent-count term in the trending score

# ---- metrics ----
LATENCY_SAMPLES=5000
